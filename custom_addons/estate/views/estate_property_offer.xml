<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estate_property_offer_view_list" model="ir.ui.view">
        <field name="name">estate.property.offer</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list>
                <field name="price"></field>
                <field name="partner_id"></field>
                <field name="validity" />
                <field name="date_deadline" />
                <button icon="fa-check" type="object" title="Accept" name="action_accept" invisible='status in ("accepted","refused")' />
                <button icon="fa-times" type="object" title="Refuse" name="action_refuse" invisible='status in ("accepted","refused")'/>
                <field name="status"></field>
            </list>
        </field>
    </record>

    <record id="estate_property_offer_view_form" model="ir.ui.view">
        <field name="name">estate.property.offer</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="price"></field>
                        <field name="validity" />
                        <field name="date_deadline" />
                        <field name="partner_id"></field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
