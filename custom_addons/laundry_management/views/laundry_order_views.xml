<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="laundry_order_action" model="ir.actions.act_window">
        <field name="name">landry.order.action</field>
        <field name="res_model">laundry.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="laundry_order_view_list" model="ir.ui.view">
        <field name="name">laundry.order.view.list</field>
        <field name="model">laundry.order</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name" />
                <field name="partner_id" />
            </list>
        </field>
    </record>

    <record id="laundry_order_view_form" model="ir.ui.view">
        <field name="name">laundry.order.view.form</field>
        <field name="model">laundry.order</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_customer_order" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="order_count" widget="statinfo" string="Orders"/>
                            <field name="partner_id" widget="statinfo" string="Orders"/>
                        </button>
                    </div>
                    <header>
                    <button name="action_received" string="Received" type="object" class="btn-primary" invisible="state != 'draft'" />
                    <button name="action_washing" string="Washing" type="object" class="btn-primary" invisible="state != 'received'" />
                    <button name="action_drying" string="Drying" type="object" class="btn-primary" invisible="state != 'washing'" />
                    <button name="action_ironing" string="Ironing" type="object" class="btn-primary" invisible="state != 'drying'" />
                    <button name="action_ready" string="Ready" type="object" class="btn-primary" invisible="state != 'ironing'" />
                    <button name="action_delivered" string="Delivered" type="object" class="btn-primary" invisible="state != 'ready'" />
                    <button name="action_send_email" string="Send Email" type="object" class="btn-primary" invisible="state != 'delivered'" />
                    <field name="state" widget="statusbar"/>
                </header>
                <div class="oe_title">
                    <h1>
                        <field name="name"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="partner_id" />
                        <field name="date_received" />
                    </group>
                    <group>
                        <field name="total_price" />
                        <field name="delivered_date" invisible="state != 'delivered'" />
                    </group>
                </group>
                <notebook>
                    <page string="Items">
                        <field name="line_ids" />
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

</odoo>
