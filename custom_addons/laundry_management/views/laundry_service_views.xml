<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="laundry_service_action" model="ir.actions.act_window">
        <field name="name">laundry.service.action</field>
        <field name="res_model">laundry.service</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="laundry_service_view_list" model="ir.ui.view">
        <field name="name">laundry.service.view.tree</field>
        <field name="model">laundry.service</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name" />
                <field name="price" />
                <field name="unit" />
            </list>
        </field>
    </record>
</odoo>