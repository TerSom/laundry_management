<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_reminder" model="mail.template">
        <field name="name">Laundry Reminder</field>
        <field name="model_id" ref="model_laundry_order"/>
        <field name="subject">
        Reminder - {{ object.name }}
        </field>
        <field name="email_to">
        {{ object.partner_id.email }}
        </field>
        <field name="body_html" type="html">
            <p>Hello <t t-out="object.partner_id.name"/>
            </p>
            <p>
            Your laundry has been completed for several days.
            </p>
            <p>
            Please pick it up soon.
            </p>
            <p>
            Order :
                <strong>
                    <t t-out="object.name"/>
                </strong>
            </p>
        </field>
    </record>
</odoo>
