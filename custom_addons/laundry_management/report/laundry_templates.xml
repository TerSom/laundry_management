<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_laundry_receipt">
        <t t-foreach="docs" t-as="e">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Courier New', monospace; margin: 0 auto;">
                        <hr style="border: none; border-top: 1px dashed #000;"/>
                        <h4 class="text-center" style="margin: 10px 0;">
                            <strong>LAUNDRY RECEIPT</strong>
                        </h4>
                        <hr style="border: none; border-top: 1px dashed #000;"/>
                        <div style="margin: 15px 0;">
                            <div style="display: flex; justify-content: space-between;">
                                <span>Order No :</span>
                                <span t-field="e.name"></span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>Customer :</span>
                                <span t-field="e.partner_id.name"></span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>Date :</span>
                                <span t-field="e.date_received"></span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>Status :</span>
                                <span t-field="e.state"></span>
                            </div>
                        </div>
                        <hr style="border: none; border-top: 1px dashed #000;"/>
                        <table class="table" style="width: 100%; margin: 0 auto;">
                            <thead>
                                <tr>
                                    <th>Service</th>
                                    <th>Qty</th>
                                    <th>Price</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="items" t-value="e.line_ids"/>
                                <tr t-foreach="items" t-as="item">
                                    <td>
                                        <span t-field="item.service_id.name"></span>
                                    </td>
                                    <td>
                                        <span t-field="item.quantity"></span>
                                    </td>
                                    <td>
                                        <span t-field="item.price_unit"></span>
                                    </td>
                                    <td>
                                        <span t-field="item.subtotal"></span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <hr style="border: none; border-top: 1px dashed #000;"/>
                        <div style="display: flex; justify-content: space-between; width: 100%; margin: 0 auto;">
                            <span>
                                <strong>TOTAL :</strong>
                            </span>
                            <span t-esc="'Rp ' + '{:,}'.format(int(e.total_price)).replace(',', '.')"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>